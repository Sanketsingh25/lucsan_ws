<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="M_PI" value="3.1415926535897931" />

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <origin xyz="0 0 0.0648" rpy="0 0 0" />
    <parent link="base_footprint"/>
    <child link="base_link" />
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.24" radius="0.24" />
      </geometry>
      <origin xyz="0 0 0.14" rpy="0 0 0"/>
      <material name="white"/>
    </visual>
    <collision name="base">
      <geometry>
        <cylinder length="0.24" radius="0.24"/>
      </geometry>
      <origin xyz="0.0 0 0.14" rpy="0 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0.01 0 0"/>
      <mass value="2.4"/>
      <inertia ixx="0.019995" ixy="0.0" ixz="0.0"
               iyy="0.019995" iyz="0.0"
               izz="0.03675" />
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.00 ${0.36/2} 0.02" rpy="${-M_PI/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <geometry>
        <cylinder length="0.0276" radius="0.0848" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.0276" radius="0.0848"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.01" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001" />
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.00 -${0.36/2} 0.02" rpy="${-M_PI/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <geometry>
        <cylinder length="0.0276" radius="0.0848" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.0276" radius="0.0848"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.01" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001" />
    </inertial>
  </link>
  
<joint name="caster_front_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front_left_link"/>
    <origin xyz="0.16 0.12 -0.0224" rpy="0 0 0"/>
  </joint>

  <link name="caster_front_left_link">
    <visual>
      <geometry>
        <sphere radius="0.0424"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0424"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <inertia ixx="0.000007" ixy="0.0" ixz="0.0" iyy="0.000007" iyz="0.0" izz="0.000007" />
    </inertial>
  </link>

  <joint name="caster_front_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front_right_link"/>
    <origin xyz="0.16 -0.12 -0.0224" rpy="0 0 0"/>
  </joint>

  <link name="caster_front_right_link">
    <visual>
      <geometry>
        <sphere radius="0.0424"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0424"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <inertia ixx="0.000007" ixy="0.0" ixz="0.0" iyy="0.000007" iyz="0.0" izz="0.000007" />
    </inertial>
  </link>

  <joint name="caster_back_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_left_link"/>
    <origin xyz="-0.16 0.12 -0.0224" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_left_link">
    <visual>
      <geometry>
        <sphere radius="0.0424"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0424"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <inertia ixx="0.000007" ixy="0.0" ixz="0.0" iyy="0.000007" iyz="0.0" izz="0.000007" />
    </inertial>
  </link>

  <joint name="caster_back_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_right_link"/>
    <origin xyz="-0.16 -0.12 -0.0224" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_right_link">
    <visual>
      <geometry>
        <sphere radius="0.0424"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.0424"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01" />
      <inertia ixx="0.000007" ixy="0.0" ixz="0.0" iyy="0.000007" iyz="0.0" izz="0.000007" />
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.02 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <gazebo reference="wheel_left_link"><mu1>100.0</mu1><mu2>100.0</mu2></gazebo>
  <gazebo reference="wheel_right_link"><mu1>100.0</mu1><mu2>100.0</mu2></gazebo>
  <gazebo reference="caster_front_left_link"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>
  <gazebo reference="caster_front_right_link"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>
  <gazebo reference="caster_back_left_link"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>
  <gazebo reference="caster_back_right_link"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>
</robot>